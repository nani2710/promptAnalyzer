{
  "model": "grok",
  "displayName": "Grok (xAI)",
  "strengths": [
    "Real-time X (Twitter) data access",
    "Direct, concise responses",
    "Humor and wit capability",
    "Current events awareness",
    "Unfiltered analysis"
  ],
  "bestPractices": {
    "realTime": {
      "triggers": ["current", "latest", "recent", "today", "trend", "now", "right now", "X", "twitter"],
      "tip": "Grok has real-time access to X (Twitter) - ask for current trends, live discussions, or recent events"
    },
    "directness": {
      "triggers": ["briefly", "shortly", "quickly", "in short", "summarize", "tldr", "TL;DR"],
      "tip": "Grok favors brevity - use TL;DR, In 3 bullet points, or Be direct for terse crisp answers"
    },
    "wit": {
      "triggers": ["funny", "humorous", "sarcastic", "ironic", "witty", "joking"],
      "tip": "Grok responds well to humor prompts - specify with wit, humorously, or in a Hitchhiker Guide style"
    },
    "roleAssignment": {
      "triggers": ["you are", "act as", "persona", "play"],
      "tip": "Assign Grok a persona - it embraces character-based framing effectively"
    },
    "unfiltered": {
      "triggers": ["honest", "blunt", "no sugar coat", "frank"],
      "tip": "Tell Grok to be completely honest or do not sugarcoat for direct unvarnished analysis"
    }
  },
  "antiPatterns": [
    {
      "pattern": "please|could you|would you",
      "issue": "Conversational filler",
      "fix": "Grok is built for directness - skip the pleasantries"
    },
    {
      "pattern": "good|nice|cool|interesting",
      "issue": "Vague descriptors",
      "fix": "Be explicit: concise, sharp, factual, no fluff"
    },
    {
      "pattern": "^tell me|^give me",
      "issue": "Weak instruction",
      "fix": "Use direct verbs: Summarize, Analyze, List, Explain"
    }
  ],
  "scoringWeights": {
    "clarity": 1.3,
    "specificity": 1.2,
    "context": 0.9,
    "constraints": 1.1,
    "structure": 0.9,
    "completeness": 0.9
  },
  "category_weight_overrides": {
    "research":       { "specificity": 1.5, "context": 1.3, "constraints": 0.3, "structure": 0.5 },
    "technical":      { "specificity": 1.4, "constraints": 1.3, "clarity": 1.4, "structure": 0.8 },
    "creative":       { "clarity": 1.6, "constraints": 0.2, "structure": 0.3, "specificity": 0.7 },
    "educational":    { "clarity": 1.5, "context": 1.3, "constraints": 0.4, "structure": 0.5 },
    "conversational": { "clarity": 1.6, "constraints": 0.2, "structure": 0.3, "context": 1.2 },
    "productivity":   { "clarity": 1.4, "constraints": 1.2, "specificity": 1.2 },
    "fun":            { "clarity": 1.6, "constraints": 0.1, "structure": 0.2, "specificity": 0.6 }
  },
  "role_weight_overrides": {
    "learner":     { "clarity": 1.6, "context": 1.2, "constraints": 0.3, "structure": 0.4, "specificity": 0.8 },
    "researcher":  { "specificity": 1.5, "context": 1.3, "completeness": 1.2, "constraints": 0.3, "structure": 0.5 },
    "builder":     { "specificity": 1.5, "constraints": 1.4, "clarity": 1.4, "completeness": 1.2, "structure": 0.8 },
    "creator":     { "clarity": 1.6, "context": 1.2, "constraints": 0.2, "structure": 0.3, "specificity": 0.7 },
